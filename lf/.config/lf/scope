#!/bin/sh
# File preview handler for lf

set -C -f
IFS="$(printf '%b_' '\n')"; IFS="${IFS%_}"

resolve_path() {
    readlink -f "$1" 2>/dev/null || realpath "$1" 2>/dev/null || printf '%s' "$1"
}

sha256_hash() {
    if command -v sha256sum >/dev/null 2>&1; then
        sha256sum | cut -d' ' -f1
    else
        shasum -a 256 | cut -d' ' -f1
    fi
}

file_stat() {
    stat --printf '%n\0%i\0%F\0%s\0%W\0%Y' "$1" 2>/dev/null || \
    stat -f '%N%i%HT%z%B%m' "$1"
}

# Previewer args: $1=file $2=width $3=height $4=x $5=y
image() {
    case "${TERM_PROGRAM:-}" in
        ghostty|kitty)
            kitten icat --stdin no --transfer-mode memory \
                --place "${2}x${3}@${4}x${5}" "$1" </dev/null >/dev/tty
            ;;
        *)
            chafa -f sixel -s "${2}x${3}" --animate off --polite on "$1"
            ;;
    esac
}

CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/lf"
mkdir -p "$CACHE_DIR"

case "$(file -Lb --mime-type -- "$1")" in
    image/avif)
        CACHE="$CACHE_DIR/thumb.$(file_stat "$(resolve_path "$1")" | sha256_hash).jpg"
        [ ! -f "$CACHE" ] && magick "$1" "$CACHE"
        image "$CACHE" "$2" "$3" "$4" "$5"
        ;;
    image/vnd.djvu)
        CACHE="$CACHE_DIR/thumb.$(file_stat "$(resolve_path "$1")" | sha256_hash).jpg"
        [ ! -f "$CACHE" ] && djvused "$1" -e 'select 1; save-page-with /dev/stdout' | magick -density 200 - "$CACHE"
        image "$CACHE" "$2" "$3" "$4" "$5"
        ;;
    image/svg+xml)
        CACHE="$CACHE_DIR/thumb.$(file_stat "$(resolve_path "$1")" | sha256_hash).png"
        [ ! -f "$CACHE" ] && inkscape --export-type=png --export-filename="$CACHE" "$1"
        image "$CACHE" "$2" "$3" "$4" "$5"
        ;;
    image/x-xcf)
        CACHE="$CACHE_DIR/thumb.$(file_stat "$(resolve_path "$1")" | sha256_hash).jpg"
        [ ! -f "$CACHE" ] && magick "$1[0]" "$CACHE"
        image "$CACHE" "$2" "$3" "$4" "$5"
        ;;
    image/*)
        image "$1" "$2" "$3" "$4" "$5"
        ;;
    text/html)
        lynx -width="$2" -display_charset=utf-8 -dump "$1"
        ;;
    text/troff)
        man ./ "$1" | col -b
        ;;
    text/* | */xml | application/json | application/x-ndjson)
        bat -p --theme ansi --terminal-width "$(($2-2))" -f "$1"
        ;;
    audio/* | application/octet-stream)
        mediainfo "$1"
        ;;
    video/*)
        CACHE="$CACHE_DIR/thumb.$(file_stat "$(resolve_path "$1")" | sha256_hash).jpg"
        [ ! -f "$CACHE" ] && ffmpegthumbnailer -i "$1" -o "$CACHE" -s 0
        image "$CACHE" "$2" "$3" "$4" "$5"
        ;;
    */pdf)
        CACHE="$CACHE_DIR/thumb.$(file_stat "$(resolve_path "$1")" | sha256_hash).jpg"
        [ ! -f "$CACHE" ] && pdftoppm -jpeg -f 1 -singlefile "$1" "$CACHE"
        image "$CACHE.jpg" "$2" "$3" "$4" "$5"
        ;;
    */epub+zip|*/mobi*)
        CACHE="$CACHE_DIR/thumb.$(file_stat "$(resolve_path "$1")" | sha256_hash).jpg"
        [ ! -f "$CACHE" ] && gnome-epub-thumbnailer "$1" "$CACHE"
        image "$CACHE" "$2" "$3" "$4" "$5"
        ;;
    application/*zip)
        atool --list -- "$1"
        ;;
    *opendocument*)
        odt2txt "$1"
        ;;
    application/pgp-encrypted)
        gpg -d -- "$1"
        ;;
esac

exit 1
