#!/bin/sh
case "${TERM_PROGRAM:-}" in
    ghostty|kitty)
        kitten icat --clear --stdin no --transfer-mode memory </dev/null >/dev/tty
        ;;
    *)
        lines="${3:-$(tput lines)}"
        i=0
        while [ "$i" -lt "$lines" ]; do
            printf '\n'
            i=$((i+1))
        done
        ;;
esac
