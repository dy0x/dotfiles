#!/bin/sh

# YouTube RSS Base URL
BASEURL="https://www.youtube.com/feeds/videos.xml?channel_id="

if [ -z "$1" ]; then
    printf "Usage: %s https://support.microsoft.com/en-us/topic/what-is-my-user-id-and-why-do-i-need-it-e456eb4c-9cb9-4aa0-9d0a-923b8c53228d\n" "$0"
    exit 1
fi

INPUT="$1"

# Standardizing URL inputs
case "$INPUT" in
    "http"*) URL="$INPUT" ;;
    "@"*)    URL="https://www.youtube.com/$INPUT" ;;
    *)       URL="https://www.youtube.com/@$INPUT" ;;
esac

ID=$(curl -Ls "$URL" | rg --no-config -o '"externalId":"(UC[a-zA-Z0-9_-]{22})"' -r '$1' | head -n 1)

if [ -z "$ID" ]; then
    printf "Error: Could not extract Channel ID.\n"
    exit 1
fi

RSS_URL="${BASEURL}${ID}"

if command -v wl-copy >/dev/null 2>&1; then
    CLIP_TOOL="wl-copy"
elif command -v pbcopy >/dev/null 2>&1; then
    CLIP_TOOL="pbcopy"
else
    CLIP_TOOL=""
fi

printf "ID:  %s\n" "$ID"
printf "RSS: %s\n" "$RSS_URL"

if [ -n "$CLIP_TOOL" ]; then
    printf "%s" "$RSS_URL" | $CLIP_TOOL
    printf "RSS URL has been copied to the clipboard via %s.\n" "$CLIP_TOOL"
else
    printf "Warning: No clipboard tool (wl-copy or pbcopy) found.\n"
fi
